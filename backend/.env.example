# Runtime
PORT=8000
ENVIRONMENT=production

# App database (RDS Postgres recommended in AWS)
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>

# Snowflake connection
SNOWFLAKE_USER=<service_user>
SNOWFLAKE_ACCOUNT=<account_identifier>
SNOWFLAKE_DATABASE=DB_BT_UA
SNOWFLAKE_SCHEMA=BT_UA_MART_ANALYTICS
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=SYNAPSE_APP_ROLE
# Con PAT, el conector no envía role: en Snowflake ejecuta
# ALTER USER <service_user> SET DEFAULT_ROLE = SYNAPSE_APP_ROLE;

# Auth mode: token or password (recommended: token)
SNOWFLAKE_AUTH_METHOD=token
SNOWFLAKE_TOKEN=<programmatic_access_token>
# SNOWFLAKE_PASSWORD=<only_if_auth_method_password>
