# Runtime
PORT=8000
ENVIRONMENT=production

# App database (RDS Postgres recommended in AWS)
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<database>

# Snowflake connection
SNOWFLAKE_USER=<service_user>
SNOWFLAKE_ACCOUNT=<account_identifier>
SNOWFLAKE_DATABASE=DB_BT_UA
SNOWFLAKE_SCHEMA=BT_UA_MART_ANALYTICS
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_ROLE=SYNAPSE_APP_ROLE
# Con PAT, el conector no envía role: en Snowflake ejecuta
# ALTER USER <service_user> SET DEFAULT_ROLE = SYNAPSE_APP_ROLE;

# Auth mode: token or password (recommended: token)
SNOWFLAKE_AUTH_METHOD=token
SNOWFLAKE_TOKEN=<programmatic_access_token>
# SNOWFLAKE_PASSWORD=<only_if_auth_method_password>

# Opcional: override explícito de la capa Gold (por defecto = DATABASE/SCHEMA)
# SNOWFLAKE_GOLD_DATABASE=DB_BT_UA
# SNOWFLAKE_GOLD_SCHEMA=BT_UA_MART_ANALYTICS
#
# Tablero GET /api/dashboard/daily-overview (solo identificadores [A-Z][A-Z0-9_]*)
# SYNAPSE_DASHBOARD_FCT_TABLE=FCT_PERFORMANCE
# SYNAPSE_DASHBOARD_PRODUCT_SALES_TABLE=VENTAS_PRODUCTOS_FUENTE
# SYNAPSE_DASHBOARD_PRODUCT_NAME_COLUMN=NOMBRE_PRODUCTO_POR_ID_PRODUCTO
# Columna de fecha en ventas por producto (NONE = sin filtro por fecha en esa consulta)
# SYNAPSE_DASHBOARD_PRODUCT_SALES_DATE_COLUMN=DATE
# SYNAPSE_DASHBOARD_ACTIVE_CAMPAIGNS_ROW_CAP=250
# Tabla de targets en Gold (nombre calificado db.schema.table) para comparativos vs target
# SNOWFLAKE_GOLD_TARGET_TABLE=

# Catálogo multi-tabla (DATA_STRUCTURE): cuántas tablas/vistas muestrear y filas por muestra
# SNOWFLAKE_CATALOG_MAX_TABLES=8
# SNOWFLAKE_CATALOG_ROW_LIMIT=18

# --- Cortex (solo Snowflake; narrativa y NL→SQL vía API REST en la cuenta) ---
# Por defecto: solo Cortex (no motor legacy Python con SQL propio + COMPLETE).
# SYNAPSE_QUERY_MODE=cortex_analyst
#
# legacy = SQL/narrativa orquestados en Python (solo si explícitamente lo permites abajo)
# SYNAPSE_QUERY_MODE=legacy
# SYNAPSE_ALLOW_LEGACY=false
#
# URL base REST (copia de Admin / cuenta en Snowflake; suele incluir región/cloud)
# Ej: https://xy12345.us-east-1.aws.snowflakecomputing.com
# SNOWFLAKE_REST_BASE_URL=
#
# Una de estas tres (obligatorio en modo cortex_analyst):
# CORTEX_ANALYST_SEMANTIC_VIEW=DB_BT_UA.BT_UA_MART_ANALYTICS.MI_SEMANTIC_VIEW
# CORTEX_ANALYST_SEMANTIC_MODEL_FILE=@DB_BT_UA.BT_UA_MART_ANALYTICS.MI_STAGE/mi_modelo.yaml
# CORTEX_ANALYST_SEMANTIC_MODELS_JSON=[{"semantic_view":"DB.SCHEMA.V1"},{"semantic_view":"DB.SCHEMA.V2"}]
#
# Opcional: ejecutar en Snowflake el SQL que devuelve Analyst y devolver tabla (solo SELECT/WITH)
# SYNAPSE_ANALYST_EXECUTE_SQL=false
# SYNAPSE_ANALYST_MAX_ROWS=500
# CORTEX_ANALYST_TIMEOUT_SEC=120

# Selección del endpoint Cortex REST:
# - analyst  => /api/v2/cortex/analyst/message
# - agent_run => /api/v2/cortex/agent:run
# CORTEX_API_MODE=analyst
# CORTEX_API_ENDPOINT=/api/v2/cortex/agent:run
# Fallback recomendado: si agent_run no resuelve con data/tools, reintenta analyst.
# CORTEX_AGENT_FALLBACK_TO_ANALYST=true
# Modo de fallback:
# - content_or_error: fallback por error HTTP/red o por respuesta del agent sin datos útiles
# - error_only: solo fallback por error HTTP/red (preserva respuesta agent aunque sea limitada)
# CORTEX_AGENT_FALLBACK_MODE=content_or_error
#
# Agent Run (sin objeto agent): configuración opcional para tools/models/instructions.
# Si se define, debe ser JSON object y se mergea al payload.
# CORTEX_AGENT_PAYLOAD_MODE=messages
# Opcional (agent object style): usa payload con agent_name/query/params.
# CORTEX_AGENT_PAYLOAD_MODE=named_agent_query
# SNOWFLAKE_AGENT_NAME=DB_BT_UA.BT_UA_MART_ANALYTICS.SYNAPSE_UA
# Si named_agent_query falla por formato/compatibilidad, intenta payload messages.
# CORTEX_AGENT_QUERY_PAYLOAD_FALLBACK_MESSAGES=true
# CORTEX_AGENT_RUN_CONFIG_JSON={"tool_choice":{"type":"auto"}}
# CORTEX_AGENT_THREAD_ID=0
# CORTEX_AGENT_PARENT_MESSAGE_ID=0
#
# Hilos Cortex (POST /api/v2/cortex/threads + parent_message_id por turno). Por defecto activo en agent_run.
# CORTEX_USE_AGENT_THREADS=true
# CORTEX_ORIGIN_APPLICATION=synapse
# CORTEX_THREAD_HTTP_TIMEOUT_SEC=30

# Timeouts Snowflake para evitar requests colgados
# SNOWFLAKE_LOGIN_TIMEOUT_SEC=15
# SNOWFLAKE_NETWORK_TIMEOUT_SEC=60
# SNOWFLAKE_STATEMENT_TIMEOUT_SEC=90
